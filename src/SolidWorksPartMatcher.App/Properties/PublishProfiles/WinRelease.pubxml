<?xml version="1.0" encoding="utf-8"?>
<!--
  Publish profile: Windows x64, self-contained, Release.
  Run from repo root:
    dotnet publish src\SolidWorksPartMatcher.App\SolidWorksPartMatcher.App.csproj /p:PublishProfile=WinRelease
  Or use publish.ps1 which also zips the output.
-->
<Project ToolsVersion="4.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>x64</Platform>
    <PublishDir>$(MSBuildThisFileDirectory)..\..\..\..\publish\SolidWorksPartMatcher-v$(Version)\</PublishDir>
    <PublishProtocol>FileSystem</PublishProtocol>
    <TargetFramework>net8.0-windows</TargetFramework>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <!-- ReadyToRun pre-JITs managed code for faster startup on target machines. -->
    <PublishReadyToRun>true</PublishReadyToRun>
    <!-- Not single-file: WPF resources and native DLLs (SQLite, SW interop) are
         more reliable as loose files alongside the exe. -->
    <PublishSingleFile>false</PublishSingleFile>
    <!-- Trim is disabled: WPF + COM reflection cannot survive IL trimming. -->
    <PublishTrimmed>false</PublishTrimmed>
  </PropertyGroup>
</Project>
