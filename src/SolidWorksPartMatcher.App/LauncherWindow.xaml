<Window x:Class="SolidWorksPartMatcher.App.LauncherWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tytle 3D Model Comparator" Height="280" Width="640"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        FontFamily="Segoe UI" FontSize="13">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" BorderBrush="#DDD" BorderThickness="0,0,0,1" Padding="16,10">
            <StackPanel>
                <TextBlock Text="Tytle 3D Model Comparator"
                           FontSize="15" FontWeight="SemiBold"/>
                <TextBlock Text="Select a comparison mode to continue."
                           Foreground="#666" FontSize="12" Margin="0,2,0,0"/>
            </StackPanel>
        </Border>

        <!-- Option panels -->
        <Grid Grid.Row="1" Margin="16,14,16,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Panel 1 — Components -->
            <Border Grid.Column="0"
                    BorderBrush="#DDD" BorderThickness="1" Padding="14,10">
                <DockPanel>
                    <Button DockPanel.Dock="Bottom"
                            Content="Open" HorizontalAlignment="Left"
                            Margin="0,10,0,0" Click="Components_Click"
                            AutomationProperties.Name="Open component comparison"/>
                    <StackPanel>
                        <TextBlock Text="Compare 3D Components"
                                   FontWeight="SemiBold" FontSize="14" Margin="0,0,0,6"/>
                        <TextBlock TextWrapping="Wrap" Foreground="#555" FontSize="12"
                                   Text="Find duplicates and geometry matches across individual SLDPRT and STEP part files."/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Panel 2 — Assemblies -->
            <Border Grid.Column="2"
                    BorderBrush="#DDD" BorderThickness="1" Padding="14,10">
                <DockPanel>
                    <Button DockPanel.Dock="Bottom"
                            Content="Open" HorizontalAlignment="Left"
                            Margin="0,10,0,0" Click="Assemblies_Click"
                            AutomationProperties.Name="Open assembly comparison"/>
                    <StackPanel>
                        <TextBlock Text="Compare 3D Assemblies"
                                   FontWeight="SemiBold" FontSize="14" Margin="0,0,0,6"/>
                        <TextBlock TextWrapping="Wrap" Foreground="#555" FontSize="12"
                                   Text="Compare different versions of SolidWorks assembly files and track structural changes between revisions."/>
                    </StackPanel>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
