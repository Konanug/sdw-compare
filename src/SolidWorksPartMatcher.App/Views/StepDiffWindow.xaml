<Window x:Class="SolidWorksPartMatcher.App.Views.StepDiffWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="3D Part Comparison" Height="460" Width="290"
        WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI" FontSize="13"
        ResizeMode="CanResizeWithGrip">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Title bar ──────────────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="#263238" Padding="12,8">
            <TextBlock x:Name="TitleLabel" Foreground="White" FontSize="15"
                       FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
        </Border>

        <!-- ── File selector ─────────────────────────────────────────────── -->
        <Border Grid.Row="1" Background="#ECEFF1"
                BorderBrush="#CFD8DC" BorderThickness="0,0,0,1">
            <DockPanel Margin="10">
                <Button DockPanel.Dock="Bottom" x:Name="CompareButton"
                        Content="Compare Selected"
                        Padding="8,5" Margin="0,10,0,0"
                        HorizontalAlignment="Stretch"
                        Click="Compare_Click"/>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Select files to compare:"
                                   FontWeight="SemiBold" Margin="0,0,0,8"
                                   Foreground="#37474F"/>
                        <StackPanel x:Name="FileSelectionPanel"/>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ── Loading indicator + status ───────────────────────────────── -->
        <StackPanel Grid.Row="2" Margin="10,6,10,2">
            <ProgressBar x:Name="LoadingBar"
                         IsIndeterminate="True"
                         Height="4"
                         Foreground="#00E576"
                         Visibility="Collapsed"
                         Margin="0,0,0,5"/>
            <TextBlock x:Name="SummaryLabel"
                       FontSize="12" Foreground="#455A64"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <!-- ── Button bar ─────────────────────────────────────────────────── -->
        <DockPanel Grid.Row="3" Margin="8,0,8,8">
            <Button DockPanel.Dock="Right" Content="Close" Padding="10,4"
                    IsCancel="True" Click="Close_Click"/>
        </DockPanel>
    </Grid>
</Window>
