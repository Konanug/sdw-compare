<Window x:Class="SolidWorksPartMatcher.App.Views.StepDiffWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="3D Part Comparison" Height="720" Width="1050"
        WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI" FontSize="13">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Title bar ──────────────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="#263238" Padding="12,8">
            <TextBlock x:Name="TitleLabel" Foreground="White" FontSize="15"
                       FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
        </Border>

        <!-- ── File selector + 3D viewport ───────────────────────────────── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- File selector panel -->
            <Border Grid.Column="0" Background="#ECEFF1"
                    BorderBrush="#CFD8DC" BorderThickness="0,0,1,0">
                <DockPanel Margin="10">
                    <Button DockPanel.Dock="Bottom" x:Name="CompareButton"
                            Content="Compare Selected"
                            Padding="8,5" Margin="0,10,0,0"
                            HorizontalAlignment="Stretch"
                            Click="Compare_Click"/>
                    <StackPanel>
                        <TextBlock Text="Select files to compare:"
                                   FontWeight="SemiBold" Margin="0,0,0,8"
                                   Foreground="#37474F"/>
                        <StackPanel x:Name="FileSelectionPanel"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Single 3D viewport — all selected parts overlapping -->
            <Border Grid.Column="1" Background="#F0F4F8">
            <Viewport3D x:Name="MainViewport"
                        ClipToBounds="True"
                        MouseLeftButtonDown="Viewport_MouseLeftButtonDown"
                        MouseMove="Viewport_MouseMove"
                        MouseLeftButtonUp="Viewport_MouseLeftButtonUp"
                        MouseWheel="Viewport_MouseWheel">
                <Viewport3D.Camera>
                    <PerspectiveCamera x:Name="MainCamera"
                                       Position="0,0,1"
                                       LookDirection="0,0,-1"
                                       UpDirection="0,1,0"
                                       FieldOfView="45"
                                       NearPlaneDistance="0.00001"
                                       FarPlaneDistance="10000"/>
                </Viewport3D.Camera>
                <!-- Static lights — never replaced between renders -->
                <ModelVisual3D>
                    <ModelVisual3D.Content>
                        <Model3DGroup>
                            <DirectionalLight Color="#BBBBBB" Direction="-1,-2,-1"/>
                            <DirectionalLight Color="#666666" Direction="1,1,0.5"/>
                            <AmbientLight Color="#555555"/>
                        </Model3DGroup>
                    </ModelVisual3D.Content>
                </ModelVisual3D>
                <!-- Dynamic content replaced on each Compare -->
                <ModelVisual3D x:Name="PartsVisual"/>
            </Viewport3D>
            </Border>
        </Grid>

        <!-- ── Legend bar ─────────────────────────────────────────────────── -->
        <Border Grid.Row="2" Background="#ECEFF1" Padding="10,6"
                BorderBrush="#CFD8DC" BorderThickness="0,1,0,1">
            <WrapPanel x:Name="LegendPanel" Orientation="Horizontal" VerticalAlignment="Center"/>
        </Border>

        <!-- ── Button bar ─────────────────────────────────────────────────── -->
        <DockPanel Grid.Row="3" Margin="8,6,8,8">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Content="Reset View" Padding="10,4" Margin="0,0,6,0"
                        Click="ResetView_Click"/>
                <Button Content="Close" Padding="10,4" IsCancel="True"
                        Click="Close_Click"/>
            </StackPanel>
            <TextBlock x:Name="SummaryLabel" VerticalAlignment="Center"
                       FontSize="12" Foreground="#455A64"/>
        </DockPanel>
    </Grid>
</Window>
