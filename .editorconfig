# EditorConfig — coding conventions for Tytle 3D Model Comparator.
# https://editorconfig.org  ·  applied by `dotnet format`.
root = true

[*]
charset = utf-8
# Repository stores LF (see .gitattributes); Git converts to CRLF on Windows checkout.
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{csproj,props,targets,xml,xaml}]
indent_size = 2

[*.{yml,yaml,json}]
indent_size = 2

[*.py]
indent_size = 4

[*.md]
trim_trailing_whitespace = false

[*.cs]
# Language conventions
csharp_style_namespace_declarations = file_scoped:suggestion
csharp_prefer_braces = when_multiline:silent
csharp_using_directive_placement = outside_namespace:suggestion
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = false
# 'this.' is not used in this codebase
dotnet_style_qualification_for_field = false:suggestion
dotnet_style_qualification_for_property = false:suggestion
dotnet_style_qualification_for_method = false:suggestion
dotnet_style_qualification_for_event = false:suggestion
# Prefer language keywords (int) over framework types (Int32)
dotnet_style_predefined_type_for_locals_parameters_members = true:suggestion
dotnet_style_predefined_type_for_member_access = true:suggestion
# Expression-level preferences
csharp_style_var_for_built_in_types = false:silent
csharp_style_var_when_type_is_apparent = true:silent
